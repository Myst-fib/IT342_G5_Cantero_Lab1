<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@color/white" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:right="0dp" android:top="0dp" android:bottom="0dp" android:left="0dp">
        <shape>
            <solid android:color="@color/white" />
            <stroke android:width="4dp" android:color="@color/primary_dark" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>