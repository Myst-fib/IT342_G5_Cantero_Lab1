<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top row: avatar + name/purpose + status badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Avatar -->
            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/gradient_button" android:gravity="center">
                    <TextView android:id="@+id/tvInitial"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="V" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/white" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Name + purpose -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvVisitorName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Visitor Name" android:textSize="15sp"
                    android:textStyle="bold" android:textColor="@color/text_dark" />
                <TextView android:id="@+id/tvPurpose"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Purpose" android:textSize="12sp"
                    android:textColor="@color/primary_dark"
                    android:background="@drawable/purpose_badge_bg"
                    android:paddingStart="8dp" android:paddingEnd="8dp"
                    android:paddingTop="2dp" android:paddingBottom="2dp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Status badge -->
            <TextView android:id="@+id/tvStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Active" android:textSize="11sp" android:textStyle="bold"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="4dp" android:paddingBottom="4dp"
                android:background="@drawable/status_active_bg" />

        </LinearLayout>

        <!-- Info row: Host + Contact + Time In -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Host" android:textSize="10sp" android:textColor="@color/text_light"
                    android:textAllCaps="true" android:letterSpacing="0.05" />
                <TextView android:id="@+id/tvHost"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="13sp" android:textColor="@color/text_dark"
                    android:textStyle="bold" android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Contact" android:textSize="10sp" android:textColor="@color/text_light"
                    android:textAllCaps="true" android:letterSpacing="0.05" />
                <TextView android:id="@+id/tvContact"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="13sp" android:textColor="@color/text_dark"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Time In" android:textSize="10sp" android:textColor="@color/text_light"
                    android:textAllCaps="true" android:letterSpacing="0.05" />
                <TextView android:id="@+id/tvTimeIn"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--:--" android:textSize="13sp" android:textColor="@color/primary_dark"
                    android:textStyle="bold" android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border_light" android:layout_marginBottom="10dp" />

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <!-- Check Out (only for ACTIVE) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckOut"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Check Out"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:background="@drawable/gradient_button"
                android:layout_marginEnd="8dp"
                android:visibility="gone"
                app:cornerRadius="8dp"
                android:stateListAnimator="@null" />

            <!-- Time Out (shown when COMPLETED) -->
            <LinearLayout
                android:id="@+id/layoutTimeOut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginEnd="8dp"
                android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Time Out" android:textSize="10sp" android:textColor="@color/text_light"
                    android:textAllCaps="true" />
                <TextView android:id="@+id/tvTimeOut"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--:--" android:textSize="13sp" android:textColor="@color/text_dark"
                    android:textStyle="bold" android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Edit button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_nav_visitors"
                app:iconSize="18dp"
                app:iconTint="@color/primary_dark"
                android:backgroundTint="@color/white"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1.5dp"
                app:cornerRadius="8dp"
                android:stateListAnimator="@null"
                android:visibility="gone" />

            <!-- Delete button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_nav_dashboard"
                app:iconSize="18dp"
                app:iconTint="@color/error"
                android:backgroundTint="@color/white"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1.5dp"
                app:cornerRadius="8dp"
                android:stateListAnimator="@null"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>